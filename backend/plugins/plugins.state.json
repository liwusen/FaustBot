{
  "plugins": {
    "example_echo": {
      "enabled": true
    },
    "clipboard": {
      "enabled": true
    },
    "search_tools": {
      "enabled": true
    },
    "context_manager": {
      "enabled": true
    },
    "ui_operator": {
      "enabled": true
    }
  },
  "configs": {
    "clipboard": {
      "schema": [
        {
          "key": "ENABLE_CLIPBOARD_READ",
          "type": "bool",
          "label": "启用剪贴板读取",
          "description": "",
          "default": true
        },
        {
          "key": "ENABLE_CLIPBOARD_WRITE",
          "type": "bool",
          "label": "启用剪贴板写入",
          "description": "",
          "default": true
        }
      ],
      "values": {
        "Enable": true,
        "ENABLE_CLIPBOARD_READ": true,
        "ENABLE_CLIPBOARD_WRITE": true
      }
    },
    "search_tools": {
      "schema": [
        {
          "key": "SEARCH_ENGINE",
          "type": "str",
          "label": "SearchAPI引擎",
          "description": "",
          "default": "google"
        },
        {
          "key": "SEARCHAPI_API_KEY",
          "type": "str",
          "label": "SearchAPI Key(使用__MAIN_CONFIG__表示主配置)",
          "description": "",
          "default": "__MAIN_CONFIG__"
        },
        {
          "key": "ENABLE_SEARCHAPI",
          "type": "bool",
          "label": "启用SearchAPI搜索",
          "description": "",
          "default": true
        },
        {
          "key": "ENABLE_WIKIPEDIA",
          "type": "bool",
          "label": "启用Wikipedia搜索",
          "description": "",
          "default": true
        }
      ],
      "values": {
        "SEARCH_ENGINE": "google",
        "ENABLE_SEARCHAPI": true,
        "ENABLE_WIKIPEDIA": true,
        "SEARCHAPI_API_KEY": ""
      }
    },
    "context_manager": {
      "schema": [
        {
          "key": "TRIGGER_USER_KEEP",
          "type": "int",
          "label": "<Trigger>消息保留条数",
          "description": "",
          "default": 3
        },
        {
          "key": "NORMAL_USER_KEEP",
          "type": "int",
          "label": "普通用户消息保留条数",
          "description": "",
          "default": 50
        }
      ],
      "values": {
        "TRIGGER_USER_KEEP": 4,
        "NORMAL_USER_KEEP": 50
      }
    },
    "ui_operator": {
      "schema": [
        {
          "key": "OCR_LANGS",
          "type": "json",
          "label": "OCR语言列表",
          "description": "",
          "default": [
            "ch_sim",
            "en"
          ]
        },
        {
          "key": "OCR_GPU",
          "type": "bool",
          "label": "OCR启用GPU",
          "description": "",
          "default": false
        },
        {
          "key": "OCR_MIN_CONF",
          "type": "float",
          "label": "OCR最小置信度",
          "description": "",
          "default": 0.3
        },
        {
          "key": "PYAUTOGUI_PAUSE",
          "type": "float",
          "label": "每次GUI动作间隔秒数",
          "description": "",
          "default": 0.05
        },
        {
          "key": "PYAUTOGUI_FAILSAFE",
          "type": "bool",
          "label": "启用鼠标角落紧急停止",
          "description": "",
          "default": true
        },
        {
          "key": "DEFAULT_TYPE_INTERVAL",
          "type": "float",
          "label": "默认打字间隔秒数",
          "description": "",
          "default": 0.02
        },
        {
          "key": "SCROLL_STEP",
          "type": "int",
          "label": "滚轮每档默认步长",
          "description": "",
          "default": 300
        }
      ],
      "values": {
        "OCR_LANGS": [
          "ch_sim",
          "en"
        ],
        "OCR_GPU": true,
        "OCR_MIN_CONF": 0.3,
        "PYAUTOGUI_PAUSE": 0.1,
        "PYAUTOGUI_FAILSAFE": true,
        "DEFAULT_TYPE_INTERVAL": 0.02,
        "SCROLL_STEP": 300
      }
    }
  }
}